@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Dashboard";
    var statsJson = Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));
}

<link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />

<div class="container-fluid mt-4 dashboard-wrapper">

    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="dash-header-title">Dashboard</h2>
            <div class="dash-subtitle">Plan, prioritize, and manage reports with ease.</div>
        </div>
        <div class="d-flex gap-3">
            @if (User.IsInRole("SuperAdmin"))
            {
                <button class="btn-pill btn-outline-custom">
                    <i class="dx-icon-user"></i> Quyền: Admin
                </button>
            }
            <button class="btn-pill btn-dark-green">
                <i class="dx-icon-plus"></i> Add Report
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-lg-6">
            <div class="dash-card card-featured">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="card-title-sm">Tổng Khách Hàng</div>
                    <i class="dx-icon-globe fs-4"></i>
                </div>
                <div class="stat-number">24</div>
                <div class="stat-subtitle">
                    <i class="dx-icon-check"></i> Hoạt động ổn định
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="dash-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="card-title-sm">Tổng Mẫu In</div>
                    <i class="dx-icon-folder text-muted"></i>
                </div>
                <div class="stat-number text-dark">156</div>
                <div class="stat-subtitle">
                    <i class="dx-icon-spindown text-success"></i> Tăng từ tháng trước
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="dash-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="card-title-sm">Hệ Thống (VPS)</div>
                    <i class="dx-icon-preferences text-muted"></i>
                </div>
                <div class="stat-number text-dark">99%</div>
                <div class="stat-subtitle">
                    <i class="dx-icon-chart text-primary"></i> Hiệu suất hôm nay
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6">
            <div class="dash-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="card-title-sm">Cần Xử Lý</div>
                    <i class="dx-icon-warning text-muted"></i>
                </div>
                <div class="stat-number text-dark">2</div>
                <div class="stat-subtitle">
                    <span class="text-warning">On Discuss</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-5">
            <div class="dash-card">
                <div class="card-title-sm">Tỷ trọng Mẫu in (Project Progress)</div>
                <div id="pieChart" style="height: 350px;"></div>
            </div>
        </div>

        <div class="col-xl-7">
            <div class="dash-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="card-title-sm mb-0">Danh sách Khách hàng (Tenants)</div>
                    <button class="btn btn-sm btn-light rounded-pill border">+ New</button>
                </div>
                <div id="gridContainer"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.dashboardRawData = @statsJson;
    </script>

    <script src="~/js/viewer.part.bundle.js"></script>

    <script src="~/js/pages/dashboard.js" asp-append-version="true"></script>
}