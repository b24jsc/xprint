@model Xprint.Data.UserItem

@{
    ViewData["Title"] = "Tạo Tài Khoản";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Tạo Tài Khoản Cho Khách Hàng</h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form method="post" action="/User/Create">
                        <div class="mb-3">
                            <label class="form-label">Tên đăng nhập (Username)</label>
                            <input type="text" name="Username" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <input type="text" name="plainPassword" class="form-control" placeholder="Nhập mật khẩu cho khách..." required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Họ và Tên / Tên Đơn Vị</label>
                            <input type="text" name="FullName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Vai trò (Role)</label>
                            <select name="Role" class="form-select">
                                <option value="ClientAdmin">Khách hàng (ClientAdmin)</option>
                                <option value="SuperAdmin">Quản trị hệ thống B24 (SuperAdmin)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mã Khách Hàng (Tenant ID)</label>
                            <input type="text" name="TenantId" class="form-control" placeholder="VD: SPORTS_MEDIC_01, VCN_MAIN..." required />
                            <small class="text-muted">Lưu ý: Các báo cáo sẽ được lọc theo mã này.</small>
                        </div>

                        <button type="submit" class="btn btn-success w-100">Lưu Tài Khoản</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>