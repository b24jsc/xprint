@model Xprint.Data.ReportItem

<div id="detailPanelContainer">
    <div class="mb-4">
        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Mã báo cáo (ID)</label>
        <div class="p-2 bg-light border rounded font-monospace small">@Model.Id</div>
    </div>

    <form id="frmUpdateJson">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-3">
            <label class="form-label fw-bold">Tên mẫu in</label>
            <input type="text" class="form-control bg-light" value="@Model.Name" readonly />
        </div>

        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <label class="form-label fw-bold mb-0">Dữ liệu JSON mẫu (Schema)</label>
                <button type="button" id="btnFormatJson" class="btn btn-link btn-sm p-0 text-decoration-none">Định dạng JSON</button>
            </div>
            <textarea id="jsonEditor" name="jsonContent" class="form-control font-monospace" rows="18"
                      style="background-color: #1e1e1e; color: #d4d4d4; font-size: 13px; line-height: 1.5; border-radius: 8px; padding: 15px;">@Model.JsonSchemaData</textarea>
        </div>

        <div class="d-grid gap-2 mt-4">
            <button type="button" class="btn btn-primary py-2 fw-bold" id="btnSaveJsonDetail">
                <i class="dx-icon-save me-1"></i> LƯU CẤU HÌNH
            </button>
        </div>
    </form>
</div>