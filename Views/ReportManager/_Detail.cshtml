@* Views/ReportManager/_Detail.cshtml *@
@model Xprint.Data.ReportItem

<form id="frmDetail" onsubmit="event.preventDefault(); return false;">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mb-3">
        <label class="form-label text-muted fs-7 text-uppercase fw-bold">Tên báo cáo</label>
        <input type="text" class="form-control" value="@Model.Name" readonly style="background-color: var(--bs-secondary-bg);" />
    </div>

    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-end mb-1">
            <label class="form-label text-muted fs-7 text-uppercase fw-bold mb-0">Dữ liệu mẫu (JSON Schema)</label>
            <span class="badge bg-light text-dark border">Json Editor</span>
        </div>
        <textarea name="jsonContent" class="form-control font-monospace" rows="20" spellcheck="false" style="font-size: 13px; background-color: #1e1e1e; color: #d4d4d4; border: none; padding: 1rem;">@Model.JsonSchemaData</textarea>
    </div>

    <div class="d-grid mt-4">
        <button type="button" id="btnSaveDetail" class="btn btn-primary rounded-pill">
            <i class="dx-icon-save"></i> Lưu Thay Đổi
        </button>
    </div>
</form>

<script>
    $('#btnSaveDetail').click(function () {
        var btn = $(this);
        var formData = new FormData($('#frmDetail')[0]);
        formData.append('__RequestVerificationToken', $('meta[name="csrf-token"]').attr('content'));

        btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Đang lưu...');

        $.ajax({
            url: '/ReportManager/UpdateJsonSchema', // Dùng lại API hôm trước
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
                DevExpress.ui.notify("Lưu thành công!", "success", 2000);
                btn.prop('disabled', false).html('<i class="dx-icon-save"></i> Lưu Thay Đổi');
                // Có thể gọi reloadGridData() ở đây nếu cần
            },
            error: function (xhr) {
                alert("Lỗi: " + xhr.responseText);
                btn.prop('disabled', false).html('<i class="dx-icon-save"></i> Lưu Thay Đổi');
            }
        });
    });
</script>