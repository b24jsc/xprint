<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Xprint B24</title>

    <link rel="stylesheet" href="~/css/thirdparty.bundle.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dx.dark.bundle.css" />

    <style>
        /* Tinh chỉnh nhỏ cho Navbar để phù hợp với Dark Theme */
        .navbar-custom {
            background-color: #222831;
        }

        .dropdown-menu-dark {
            background-color: #393E46;
            border: 1px solid #222831;
        }

            .dropdown-menu-dark .dropdown-item {
                color: #eeeeee;
            }

                .dropdown-menu-dark .dropdown-item:hover {
                    background-color: #00adb5;
                    color: white;
                }
    </style>
</head>
<body class="dx-viewport">
    <div class="container-fluid vh-100 d-flex flex-column p-0">
        <header>
            <nav class="navbar navbar-expand-md navbar-dark navbar-custom border-bottom box-shadow">
                <div class="container-fluid">
                    <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/lib/img/xbook-icon.svg" width="28" height="28" class="mr-2" alt="Xprint Logo" />
                        <span class="font-weight-bold" style="letter-spacing: 1px;">XPRINT</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex">
                        <ul class="navbar-nav mr-auto">
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">
                                    Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="ReportDesigner">
                                    Design
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-controller="ReportManager" asp-action="Index">
                                    ReportManager
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Cấu hình
                                </a>
                                <div class="dropdown-menu dropdown-menu-dark shadow" aria-labelledby="navbarDropdown">
                                    <a class="dropdown-item" asp-area="" asp-controller="User" asp-action="Index">Quản lý User</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Settings" asp-action="Api">Cấu hình API</a>
                                    <div class="dropdown-divider" style="border-color: #555;"></div>
                                    <a class="dropdown-item" asp-area="" asp-controller="Settings" asp-action="Database">Kết nối Database</a>
                                </div>
                            </li>
                        </ul>

                        <ul class="navbar-nav">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item d-flex align-items-center">
                                    <span class="text-info mr-3">Xin chào, <strong>@User.Identity.Name</strong></span>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-outline-danger btn-sm mt-1" asp-area="" asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container-fluid flex-grow-1 d-flex flex-column p-3">
            <main role="main" class="flex-grow-1">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted mt-auto" style="background-color: #222831; border-color: #333 !important;">
            <div class="container-fluid text-center">
                <p class="mb-2 mt-2">&copy; @DateTime.Now.Year - Nền tảng quản lý báo cáo tập trung Xprint</p>
            </div>
        </footer>

        <script src="~/js/site.thirdparty.bundle.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @RenderSection("Scripts", false)
    </div>
</body>
</html>